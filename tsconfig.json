{
  "extends": "@voxpelli/tsconfig/node20.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "types/**/*",
    "lib/**/*",
    "bin/**/*",
    "scripts/**/*",
    "test/**/*",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "jsdoc",
    "test-workspace"
  ]
}
